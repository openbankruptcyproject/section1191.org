  "mainEntity": [
    {"@type": "Question", "name": "What is consensual confirmation under 1191(a)?",
     "acceptedAnswer": {"@type": "Answer", "text": "All impaired classes of creditors accept the plan. The court confirms if the plan meets the standard Chapter 11 confirmation requirements of Section 1129(a), with modifications for Subchapter V."}},
    {"@type": "Question", "name": "Does the absolute priority rule apply?",
     "acceptedAnswer": {"@type": "Answer", "text": "No. Under Subchapter V, the absolute priority rule does not apply. The debtor can retain ownership interest in the business even if unsecured creditors are not paid in full."}},
    {"@type": "Question", "name": "When does the discharge occur?",
     "acceptedAnswer": {"@type": "Answer", "text": "Under 1191(a) consensual confirmation, the debtor receives a discharge upon confirmation of the plan - not after completing all payments."}}
  ]
}
